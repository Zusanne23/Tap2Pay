<Window x:Class="Tap2PayKiosk.Views.OrderView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Order Food"
        Height="750"
        Width="1250"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE -->
        <StackPanel>

            <DockPanel Margin="0,0,0,10">

                <Button Content="← Back"
                        Width="90"
                        Height="35"
                        Click="btnBack_Click"
                        DockPanel.Dock="Left"/>

                <TextBlock Text="Order Food"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

            </DockPanel>

            <StackPanel Orientation="Horizontal">

                <TextBlock Text="Category:"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <ComboBox x:Name="cbCategory"
                          Width="180"
                          Height="30"
                          SelectionChanged="cbCategory_SelectionChanged">

                    <ComboBoxItem Content="All"
                                  IsSelected="True"/>
                    <ComboBoxItem Content="Meals"/>
                    <ComboBoxItem Content="Drinks"/>
                    <ComboBoxItem Content="Snacks"/>

                </ComboBox>

            </StackPanel>

            <TextBox x:Name="txtSearch"
                     Height="35"
                     Margin="0,10"
                     TextChanged="txtSearch_TextChanged"/>

            <ScrollViewer Height="600"
                          VerticalScrollBarVisibility="Auto">

                <ItemsControl x:Name="icProducts">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <Border Width="180"
                                    Height="260"
                                    Margin="10"
                                    CornerRadius="10"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"
                                    Background="White">

                                <StackPanel Margin="10">

                                    <Image Source="{Binding ImagePath}"
                                           Height="110"
                                           Stretch="UniformToFill"/>

                                    <TextBlock Text="{Binding ProductName}"
                                               FontWeight="Bold"
                                               FontSize="16"
                                               Margin="0,10,0,0"
                                               TextAlignment="Center"/>

                                    <TextBlock Text="{Binding Category}"
                                               Foreground="Gray"
                                               HorizontalAlignment="Center"/>

                                    <TextBlock Text="{Binding Price,StringFormat=₱{0:N2}}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               Margin="0,10"/>

                                    <Button Content="ADD"
                                            Height="35"
                                            Tag="{Binding}"
                                            Click="btnAdd_Click"/>

                                </StackPanel>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </ScrollViewer>

        </StackPanel>

        <!-- RIGHT SIDE -->

        <StackPanel Grid.Column="1"
                    Margin="15,0,0,0">

            <TextBlock Text="Current Order"
                       FontSize="22"
                       FontWeight="Bold"/>

            <DataGrid x:Name="dgCart"
                      Height="300"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Item"
                                        Binding="{Binding ItemName}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Qty"
                                        Binding="{Binding Quantity}"
                                        Width="60"/>

                    <DataGridTextColumn Header="Price"
                                        Binding="{Binding Price,StringFormat=₱{0:N2}}"
                                        Width="90"/>

                    <DataGridTextColumn Header="Amount"
                                        Binding="{Binding Amount,StringFormat=₱{0:N2}}"
                                        Width="100"/>

                </DataGrid.Columns>

            </DataGrid>

            <TextBlock x:Name="lblTotal"
                       Text="TOTAL : ₱0.00"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0,20"/>

            <GroupBox Header="Payment Method">

                <StackPanel Margin="10">

                    <RadioButton x:Name="rbRFID"
                                 Content="RFID Payment"
                                 IsChecked="True"/>

                    <RadioButton x:Name="rbCash"
                                 Content="Cash Payment"
                                 Margin="0,5,0,0"/>

                </StackPanel>

            </GroupBox>

            <Button x:Name="btnConfirm"
                    Content="CONFIRM ORDER"
                    Height="45"
                    Margin="0,20,0,10"
                    Click="btnConfirm_Click"/>

            <Button x:Name="btnCancel"
                    Content="CANCEL"
                    Height="40"
                    Click="btnCancel_Click"/>

        </StackPanel>

    </Grid>

</Window>