<Window x:Class="Tap2PayKiosk.Views.CheckBalanceView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Check Balance"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel>

            <Button x:Name="btnBack"
                    Content="← Back"
                    Width="100"
                    Height="35"
                    Click="btnBack_Click"
                    DockPanel.Dock="Left"/>

            <TextBlock Text="Check Balance"
                       FontSize="30"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

        </DockPanel>

        <!-- Center -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <TextBlock Text="Tap your RFID Card"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- Hidden textbox para sa USB RFID Reader -->
            <TextBox x:Name="txtRFID"
                     Width="1"
                     Height="1"
                     Opacity="0"
                     KeyDown="txtRFID_KeyDown"/>

            <Border Width="500"
                    Padding="20"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="10"
                    Background="White">

                <StackPanel>

                    <TextBlock x:Name="lblStatus"
                               Text="🟡 Waiting for RFID..."
                               FontSize="20"
                               Foreground="DarkOrange"
                               Margin="0,0,0,20"/>

                    <Separator/>

                    <TextBlock x:Name="lblName"
                               Text="Name :"
                               FontSize="20"
                               Margin="0,15"/>

                    <TextBlock x:Name="lblStudentNo"
                               Text="Student ID :"
                               FontSize="20"
                               Margin="0,10"/>

                    <TextBlock x:Name="lblBalance"
                               Text="Balance : ₱0.00"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="Green"
                               Margin="0,20"/>

                </StackPanel>

            </Border>

        </StackPanel>

        <!-- Bottom -->
        <Button x:Name="btnDone"
                Grid.Row="2"
                Content="DONE"
                Width="180"
                Height="45"
                HorizontalAlignment="Center"
                Margin="0,20"
                Click="btnDone_Click"/>

    </Grid>

</Window>