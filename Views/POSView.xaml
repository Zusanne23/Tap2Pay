<Window x:Class="Tap2PayAdmin.Views.POSView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Point of Sale"
        Height="730"
        Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE -->
        <StackPanel Grid.Column="0">

            <DockPanel Grid.Row="0" Margin="0,0,0,10">

                <Button x:Name="btnBack"
                          Content="←"
                          Width="40"
                          Height="35"
                          Click="btnBack_Click"
                          DockPanel.Dock="Left"/>

                <TextBlock Text="Point of Sale"
                          FontSize="24"
                          FontWeight="Bold"
                          HorizontalAlignment="Center"/>

            </DockPanel>

            <TextBlock Text="Available Products"
           FontSize="22"
           FontWeight="Bold"/>

            <StackPanel Orientation="Horizontal"
            Margin="0,10">

                <TextBlock Text="Category:"
               VerticalAlignment="Center"
               Margin="0,0,10,0"/>

                <ComboBox x:Name="cbCategory"
              Width="180"
              Height="30"
              SelectionChanged="cbCategory_SelectionChanged">

                    <ComboBoxItem Content="All"
                      IsSelected="True"/>

                    <ComboBoxItem Content="Meals"/>

                    <ComboBoxItem Content="Drinks"/>

                    <ComboBoxItem Content="Snacks"/>

                </ComboBox>

            </StackPanel>

            <TextBox x:Name="txtSearch"
                       Height="35"
                       Margin="0,10"
                       TextChanged="txtSearch_TextChanged"/>

            <ScrollViewer Height="560"
              VerticalScrollBarVisibility="Auto">

                <ItemsControl x:Name="icProducts">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <Border Width="190"
                                    Height="320"
                                    Margin="10"
                                    CornerRadius="10"
                                    BorderBrush="#D0D0D0"
                                    BorderThickness="1"
                                    Background="White">

                                <StackPanel Margin="10">

                                    <!-- Product Image -->
                                    <Image Source="{Binding ImagePath}"
                                   Height="110"
                                   Stretch="UniformToFill"/>        

                                    <!-- Product Name -->
                                    <TextBlock Text="{Binding ProductName}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Margin="0,10,0,0"
                                   TextAlignment="Center"/>

                                    <!-- Category -->
                                    <TextBlock Text="{Binding Category}"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"/>       

                                    <!-- Price -->
                                    <TextBlock Text="{Binding Price,StringFormat=₱{0:N2}}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,10"/>      

                                    <!-- Add Button -->
                                    <Button Content="ADD"
                                Height="35"
                                Margin="0,10,0,0"
                                Tag="{Binding}"
                                Click="btnAdd_Click"/>  

                                </StackPanel>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </ScrollViewer>

        </StackPanel>

                <!-- RIGHT SIDE -->
        <StackPanel Grid.Column="1"
                    Margin="15,0,0,0">

            <TextBlock Text="Customer Information"
                       FontSize="20"
                       FontWeight="Bold"/>

            <Border BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,10">

                <StackPanel>

                    <TextBlock x:Name="lblUserId"
                               Text="User ID :"/>

                    <TextBlock x:Name="lblName"
                               Text="Name : Waiting for RFID..."/>

                    <TextBlock x:Name="lblBalance"
                               Text="Balance : ₱0.00"/>

                </StackPanel>

            </Border>

            <TextBlock Text="Current Order"
                       FontSize="20"
                       FontWeight="Bold"/>

            <DataGrid x:Name="dgCart"
          Height="150"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="True">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Item"
                            Binding="{Binding ItemName}"
                            Width="*"/>

                    <DataGridTextColumn Header="Size"
                            Binding="{Binding Size}"
                            Width="80"/>

                    <DataGridTextColumn Header="Qty"
                            Binding="{Binding Quantity}"
                            Width="60"/>

                    <DataGridTextColumn Header="Price"
                        Binding="{Binding Price,StringFormat=₱{0:N2}}"
                        Width="90"/>    

                    <DataGridTextColumn Header="Amount"
                            Binding="{Binding Amount,StringFormat=₱{0:N2}}"
                            Width="100"/>

                </DataGrid.Columns>

            </DataGrid>
            <TextBlock x:Name="lblTotal"
           Text="TOTAL : ₱0.00"
           FontSize="14"
           FontWeight="Bold"
           Margin="0,15"/>
            <GroupBox Header="Order Size"
          Margin="0,8" Height="75">

                <StackPanel Margin="10">

                    <RadioButton x:Name="rbWhole"
                     Content="Whole"
                     IsChecked="True"/>

                    <RadioButton x:Name="rbHalf"
                     Content="Half"
                     Margin="0,5,0,0"/>

                </StackPanel>

            </GroupBox>

            <GroupBox Header="Payment Method"
          Margin="0,9">

                <StackPanel Margin="10">

                    <RadioButton x:Name="rbRFID"
                     Content="RFID Payment"
                     IsChecked="True"/>

                    <RadioButton x:Name="rbCash"
                     Content="Cash Payment"
                     Margin="0,5,0,0"/>

                </StackPanel>

            </GroupBox>

            <TextBox x:Name="txtRFID"
                     Width="1"
                     Height="1"
                     Opacity="0"
                     KeyDown="txtRFID_KeyDown"/>

            <TextBlock x:Name="lblRFID"
                      Text="🟡 Waiting for RFID..."
                      FontWeight="Bold"
                      Foreground="DarkOrange"
                      Margin="0,5"/>
            
            <Button x:Name="btnConfirm"
                    Content="CONFIRM"
                    Height="35"
                    Margin="0,15,0,5"
                    Click="btnConfirm_Click"/>

            <Button x:Name="btnCancel"
                    Content="CANCEL"
                    Height="35"
                    Click="btnCancel_Click"/>

        </StackPanel>

    </Grid>

</Window>