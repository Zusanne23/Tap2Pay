<Window x:Class="Tap2PaySystem.Views.POSView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Point of Sale"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE -->
        <StackPanel Grid.Column="0">

            <TextBlock Text="Available Items"
                       FontSize="22"
                       FontWeight="Bold"/>

            <TextBox x:Name="txtSearch"
                       Height="35"
                       Margin="0,10"
                       TextChanged="txtSearch_TextChanged"/>

            <DataGrid x:Name="dgInventory"
                      AutoGenerateColumns="False"
                      Height="560">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Item Name"
                                        Binding="{Binding ItemName}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Price"
                                        Binding="{Binding Price}"
                                        Width="90"/>

                    <DataGridTextColumn Header="Stock"
                                        Binding="{Binding Stock}"
                                        Width="90"/>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="100"/>

                    <DataGridTemplateColumn Header="Action"
                                            Width="90">

                        <DataGridTemplateColumn.CellTemplate>

                            <DataTemplate>

                                <Button Content="ADD"
                                        Click="btnAdd_Click"/>

                            </DataTemplate>

                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>

        <!-- RIGHT SIDE -->
        <StackPanel Grid.Column="1"
                    Margin="15,0,0,0">

            <TextBlock Text="Customer Information"
                       FontSize="20"
                       FontWeight="Bold"/>

            <Border BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,10">

                <StackPanel>

                    <TextBlock x:Name="lblUserId"
                               Text="User ID :"/>

                    <TextBlock x:Name="lblName"
                               Text="Name : Waiting for RFID..."/>

                    <TextBlock x:Name="lblBalance"
                               Text="Balance : ₱0.00"/>

                </StackPanel>

            </Border>

            <TextBlock Text="Current Order"
                       FontSize="20"
                       FontWeight="Bold"/>

            <DataGrid x:Name="dgCart"
          Height="220"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="True">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Item"
                            Binding="{Binding ItemName}"
                            Width="*"/>

                    <DataGridTextColumn Header="Qty"
                            Binding="{Binding Quantity}"
                            Width="60"/>

                    <DataGridTextColumn Header="Price"
                        Binding="{Binding Price,StringFormat=₱{0:N2}}"
                        Width="90"/>    

                    <DataGridTextColumn Header="Amount"
                            Binding="{Binding Amount,StringFormat=₱{0:N2}}"
                            Width="100"/>

                </DataGrid.Columns>

            </DataGrid>
            <TextBlock x:Name="lblTotal"
           Text="TOTAL : ₱0.00"
           FontSize="24"
           FontWeight="Bold"
           Margin="0,15"/>

            <GroupBox Header="Payment Method"
          Margin="0,10">

                <StackPanel Margin="10">

                    <RadioButton x:Name="rbRFID"
                     Content="RFID Payment"
                     IsChecked="True"
                     Margin="0,5"/>

                    <RadioButton x:Name="rbCash"
                     Content="Cash Payment"
                     Margin="0,5"/>

                </StackPanel>

            </GroupBox>

            <TextBlock x:Name="lblRFID"
                      Text="🟡 Waiting for RFID..."
                      FontWeight="Bold"
                      Foreground="DarkOrange"
                      Margin="0,5"/>
            
            <Button x:Name="btnConfirm"
                    Content="CONFIRM"
                    Height="45"
                    Margin="0,15,0,5"
                    Click="btnConfirm_Click"/>

            <Button x:Name="btnCancel"
                    Content="CANCEL"
                    Height="45"
                    Click="btnCancel_Click"/>

        </StackPanel>

    </Grid>

</Window>