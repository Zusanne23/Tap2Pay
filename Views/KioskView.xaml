<Window x:Class="Tap2PaySystem.Views.KioskView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tap2Pay Kiosk"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE -->
        <StackPanel Grid.Column="0">

            <TextBlock Text="Tap2Pay Cafeteria"
                       FontSize="30"
                       FontWeight="Bold"/>

            <TextBlock Text="Select your order"
                       FontSize="18"
                       Margin="0,5,0,20"/>

            <StackPanel Orientation="Horizontal">

                <TextBox x:Name="txtSearch"
                         Width="300"
                         Height="35"/>

                <Button Content="Search"
                        Width="100"
                        Margin="10,0,0,0"/>
            </StackPanel>

            <DataGrid x:Name="dgMenu"
                      Margin="0,20,0,0"
                      AutoGenerateColumns="False"
                      Height="500">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Item"
                                        Binding="{Binding ItemName}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Price"
                                        Binding="{Binding Price}"
                                        Width="100"/>

                    <DataGridTextColumn Header="Stock"
                                        Binding="{Binding Stock}"
                                        Width="80"/>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="120"/>

                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>

        <!-- RIGHT SIDE -->
        <Border Grid.Column="1"
                Margin="20,0,0,0"
                Background="White"
                CornerRadius="10"
                Padding="20">

            <StackPanel>

                <TextBlock Text="ORDER SUMMARY"
                           FontSize="24"
                           FontWeight="Bold"/>

                <DataGrid x:Name="dgCart"
                          Margin="0,20,0,20"
                          Height="350"
                          AutoGenerateColumns="True"/>

                <TextBlock Text="TOTAL"
                           FontSize="18"/>

                <TextBlock x:Name="txtTotal"
                           Text="₱0.00"
                           FontSize="30"
                           FontWeight="Bold"
                           Margin="0,10,0,20"/>

                <Button x:Name="btnProceed"
                        Content="Proceed to Payment"
                        Height="50"
                        FontSize="18"
                        Click="btnProceed_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>