<Window x:Class="Tap2PayAdmin.Views.ProductsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Products"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <DockPanel Grid.Row="0"
                   Margin="0,0,0,20">

            <Button x:Name="btnBack"
                    Width="40"
                    Height="35"
                    Content="←"
                    Click="btnBack_Click"
                    DockPanel.Dock="Left"/>

            <TextBlock Text="Products"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="15,0,0,0"
                       VerticalAlignment="Center"/>

        </DockPanel>

        <!-- DASHBOARD -->
        <UniformGrid Grid.Row="1"
                     Columns="4"
                     Margin="0,0,0,20">

            <Border Background="#3498DB"
                    CornerRadius="10"
                    Margin="5">

                <StackPanel Margin="15">

                    <TextBlock Text="Total Products"
                               Foreground="White"/>

                    <TextBlock x:Name="txtTotalProducts"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>

                </StackPanel>

            </Border>

            <Border Background="#2ECC71"
                    CornerRadius="10"
                    Margin="5">

                <StackPanel Margin="15">

                    <TextBlock Text="Available"
                               Foreground="White"/>

                    <TextBlock x:Name="txtAvailable"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>

                </StackPanel>

            </Border>

            <Border Background="#F39C12"
                    CornerRadius="10"
                    Margin="5">

                <StackPanel Margin="15">

                    <TextBlock Text="Meals"
                               Foreground="White"/>

                    <TextBlock x:Name="txtMeals"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>

                </StackPanel>

            </Border>

            <Border Background="#9B59B6"
                    CornerRadius="10"
                    Margin="5">

                <StackPanel Margin="15">

                    <TextBlock Text="Drinks"
                               Foreground="White"/>

                    <TextBlock x:Name="txtDrinks"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>

                </StackPanel>

            </Border>

        </UniformGrid>

        <!-- SEARCH -->
        <DockPanel Grid.Row="2"
                   Margin="0,0,0,15">

            <TextBox x:Name="txtSearch"
                     Width="300"
                     Height="35"
                     VerticalContentAlignment="Center"
                     DockPanel.Dock="Left"/>

            <Button x:Name="btnSearch"
                    Content="Search"
                    Width="90"
                    Height="35"
                    Margin="10,0,0,0"
                    Click="btnSearch_Click"
                    DockPanel.Dock="Left"/>

            <Button x:Name="btnAdd"
                    Content="Add Product"
                    Width="140"
                    Height="35"
                    HorizontalAlignment="Right"
                    Click="btnAdd_Click"
                    DockPanel.Dock="Right"/>

        </DockPanel>

        <!-- PRODUCTS TABLE -->
        <DataGrid x:Name="dgProducts"
                  Grid.Row="3"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="dgProducts_SelectionChanged">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Width="70"
                                    Binding="{Binding ProductId}"/>

                <DataGridTextColumn Header="Product Name"
                                    Width="280"
                                    Binding="{Binding ProductName}"/>

                <DataGridTextColumn Header="Category"
                                    Width="180"
                                    Binding="{Binding Category}"/>

                <DataGridTextColumn Header="Price"
                                    Width="120"
                                    Binding="{Binding Price,StringFormat=C}"/>

                <DataGridTextColumn Header="Status"
                                    Width="120"
                                    Binding="{Binding Status}"/>

                <DataGridTemplateColumn x:Name="editColumn"
                                        Header="Edit">
                    
                    <DataGridTemplateColumn.CellTemplate>

                        <DataTemplate>

                            <Button Content="Edit"
                                    Width="60"
                                    Height="28"
                                    Tag="{Binding}"
                                    Click="btnEdit_Click"/>

                        </DataTemplate>

                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>

                <DataGridTemplateColumn x:Name="deleteColumn"
                                        Header="Delete">
                    
                    <DataGridTemplateColumn.CellTemplate>

                        <DataTemplate>

                            <Button Content="Delete"
                                    Width="60"
                                    Height="28"
                                    Foreground="Red"
                                    Tag="{Binding}"
                                    Click="btnDelete_Click"/>

                        </DataTemplate>

                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>