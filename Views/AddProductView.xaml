<Window x:Class="Tap2PayAdmin.Views.AddProductView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product"
        Height="650"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Product Name -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">

            <TextBlock Text="Product Name"/>

            <TextBox x:Name="txtProductName"
                     Height="35"/>

        </StackPanel>

        <!-- Category -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">

            <TextBlock Text="Category"/>

            <ComboBox x:Name="cmbCategory"
                      Height="35">

                <ComboBoxItem Content="Meals"/>
                <ComboBoxItem Content="Drinks"/>
                <ComboBoxItem Content="Snacks"/>

            </ComboBox>

        </StackPanel>

        <!-- Price -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">

            <TextBlock Text="Price"/>

            <TextBox x:Name="txtPrice"
                     Height="35"/>

        </StackPanel>

        <!-- Status -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">

            <TextBlock Text="Status"/>

            <ComboBox x:Name="cmbStatus"
                      Height="35">

                <ComboBoxItem Content="Available"/>
                <ComboBoxItem Content="Unavailable"/>

            </ComboBox>

        </StackPanel>

        <!-- Product Image -->
        <StackPanel Grid.Row="4" Margin="0,0,0,15">

            <TextBlock Text="Product Image"/>

            <Border BorderBrush="Gray"
                    BorderThickness="1"
                    Width="180"
                    Height="150"
                    Margin="0,5">

                <Image x:Name="imgPreview"
                       Stretch="UniformToFill"/>

            </Border>

            <Button x:Name="btnBrowse"
                    Content="Browse Image"
                    Width="140"
                    Height="35"
                    Margin="0,10,0,0"
                    Click="btnBrowse_Click"/>

        </StackPanel>

        <!-- Save Button -->
        <Button Grid.Row="6"
                x:Name="btnSave"
                Content="Save"
                Height="40"
                Width="120"
                HorizontalAlignment="Right"
                Click="btnSave_Click"/>

    </Grid>

</Window>