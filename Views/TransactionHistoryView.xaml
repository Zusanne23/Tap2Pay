<Window x:Class="Tap2PayAdmin.Views.TransactionHistoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transaction History"
        Height="700"
        Width="1300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <DockPanel Margin="0,0,0,20">

            <Button x:Name="btnBack"
                    Width="40"
                    Height="35"
                    Content="←"
                    Click="btnBack_Click"
                    DockPanel.Dock="Left"/>

            <TextBlock Text="Transaction"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="15,0,0,0"
                       VerticalAlignment="Center"/>

        </DockPanel>

        <!-- SEARCH -->
        <Grid Grid.Row="1" Margin="0,0,0,15">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtSearch"
                     Grid.Column="0"
                     Height="35"
                     VerticalContentAlignment="Center"/> 

        </Grid>

        <!-- TABLE -->
        <DataGrid x:Name="dgTransaction"
          Grid.Row="2"
          Margin="0,5,0,0"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="True">
            <DataGrid.Columns>

                <DataGridTextColumn Header="Transaction No"
                                    Width="120"
                                    Binding="{Binding TransactionId}"/>

                <DataGridTextColumn Header="Customer"
                                    Width="170"
                                    Binding="{Binding CustomerName}"/>

                <DataGridTextColumn Header="RFID"
                                    Width="120"
                                    Binding="{Binding RFIDUID}"/>

                <DataGridTextColumn Header="Order"
                                    Width="180"
                                    Binding="{Binding OrderPurchased}"/>

                <DataGridTextColumn Header="Qty"
                                    Width="70"
                                    Binding="{Binding Quantity}"/>

                <DataGridTextColumn Header="Total"
                                    Width="100"
                                    Binding="{Binding TotalAmount,StringFormat=C}"/>

                <DataGridTextColumn Header="Date/Time"
                                    Width="170"
                                    Binding="{Binding TransactionDate}"/>

                <DataGridTextColumn Header="Status"
                                    Width="120"
                                    Binding="{Binding Status}"/>

            </DataGrid.Columns>

        </DataGrid>

        <!-- FOOTER -->
        <!-- FOOTER -->
        <Grid Grid.Row="3" Margin="0,15,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="txtTotalTransactions"
                         Grid.Column="0"
                         Text="Total Transactions: 0"
                         FontSize="16"
                         FontWeight="Bold"/>

            <TextBlock x:Name="txtTotalSales"
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        Text="Total Sales: ₱0.00"
                        FontSize="16"
                        FontWeight="Bold"/>  

        </Grid>

    </Grid>

</Window>