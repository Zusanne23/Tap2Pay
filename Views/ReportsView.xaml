<Window x:Class="Tap2PayAdmin.Views.ReportsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reports"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Margin="0,0,0,20">

            <Button x:Name="btnBack"
                    Content="←"
                    Width="40"
                    Height="35"
                    Click="btnBack_Click"
                    DockPanel.Dock="Left"/>

            <TextBlock Text="Sales Report"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

        </DockPanel>

        <!-- Summary -->
        <UniformGrid Grid.Row="1"
                     Columns="4"
                     Margin="0,0,0,20">

            <Border Background="#3498DB"
                    CornerRadius="10"
                    Margin="5">

                <StackPanel Margin="15">

                    <TextBlock Text="Registered Users"
                               FontSize="15"
                               Foreground="White"/>

                    <TextBlock x:Name="txtUsers"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"/>

                </StackPanel>

            </Border>

            <Border Background="#27AE60"
                    CornerRadius="10"
                    Margin="5">

                <StackPanel Margin="15">

                    <TextBlock Text="Transactions"
                               FontSize="15"
                               Foreground="White"/>

                    <TextBlock x:Name="txtTransactions"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"/>

                </StackPanel>

            </Border>

            <Border Background="#E67E22"
                    CornerRadius="10"
                    Margin="5">

                <StackPanel Margin="15">

                    <TextBlock Text="Total Sales"
                               FontSize="15"
                               Foreground="White"/>

                    <TextBlock x:Name="txtSales"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"/>

                </StackPanel>

            </Border>

            <Border Background="#8E44AD"
                    CornerRadius="10"
                    Margin="5">

                <StackPanel Margin="15">

                    <TextBlock Text="Total Top Up"
                               FontSize="15"
                               Foreground="White"/>

                    <TextBlock x:Name="txtTopUp"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"/>

                </StackPanel>

            </Border>

        </UniformGrid>

        <!-- Sales Table -->
        <DataGrid x:Name="dgSales"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Transaction ID"
                                    Binding="{Binding TransactionId}"
                                    Width="120"/>

                <DataGridTextColumn Header="Customer"
                                    Binding="{Binding FullName}"
                                    Width="220"/>

                <DataGridTextColumn Header="Date"
                                    Binding="{Binding TransactionDate}"
                                    Width="180"/>

                <DataGridTextColumn Header="Amount"
                                    Binding="{Binding TotalAmount,StringFormat=₱{0:N2}}"
                                    Width="150"/>

                <DataGridTextColumn Header="Payment"
                                    Binding="{Binding PaymentMethod}"
                                    Width="150"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>