<Window x:Class="Tap2PayAdmin.Views.PaymentSuccessView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Payment Successful"
        Height="650"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#8EC5E8">

    <Grid>

        <Border Width="360"
                Padding="25"
                Background="White"
                CornerRadius="15"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel>

                <TextBlock Text="✔"
                           FontSize="42"
                           Foreground="#39B54A"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Payment Successful"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#39B54A"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,20"/>

                <Grid Margin="0,0,0,15">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Name:"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="txtName"
                               Grid.Column="1"/>

                    <TextBlock Text="RFID:"
                               Grid.Row="1"
                               Margin="0,25,0,0"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="txtRFID"
                               Grid.Row="1"
                               Grid.Column="1"
                               Margin="0,25,0,0"/>

                </Grid>

                <Border BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,15">

                    <StackPanel>

                        <TextBlock Text="Order / Purchase"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Item"/>
                            <TextBlock Text="Amount"
                                       Grid.Column="1"
                                       HorizontalAlignment="Right"/>

                        </Grid>

                        <Separator Margin="0,5"/>

                        <ListView x:Name="lvReceipt"
                                  Height="150"
                                  BorderThickness="0">

                            <ListView.ItemTemplate>

                                <DataTemplate>

                                    <Grid>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding ItemName}"/>

                                        <TextBlock Grid.Column="1"
                                                   HorizontalAlignment="Right"
                                                   Text="{Binding TotalPrice,StringFormat=₱{0:N2}}"/>

                                    </Grid>

                                </DataTemplate>

                            </ListView.ItemTemplate>

                        </ListView>

                        <Separator Margin="0,8"/>

                        <Grid Margin="0,5">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="TOTAL"
                                       FontWeight="Bold"/>

                            <TextBlock x:Name="txtTotal"
                                       Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       FontWeight="Bold"/>

                        </Grid>

                    </StackPanel>

                </Border>

                <Border Background="#F4F4F4"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,20">

                    <StackPanel>

                        <TextBlock Text="Remaining Balance"
                                   HorizontalAlignment="Center"/>

                        <TextBlock x:Name="txtRemainingBalance"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#2E8B57"
                                   HorizontalAlignment="Center"/>

                    </StackPanel>

                </Border>

                <Button x:Name="btnNewTransaction"
                        Content="NEW TRANSACTION"
                        Width="200"
                        Height="42"
                        Background="#1FA31F"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="btnNewTransaction_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>