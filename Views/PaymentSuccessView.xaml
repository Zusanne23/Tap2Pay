<Window x:Class="Tap2PaySystem.Views.PaymentSuccessView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Payment Successful"
        Height="600"
        Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4F6F9">

    <Grid>

        <Border Width="550"
                Height="500"
                Background="White"
                CornerRadius="15"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Margin="20">

                <TextBlock Text="PAYMENT SUCCESSFUL"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="Green"
                           HorizontalAlignment="Center"
                           Margin="0,10"/>

                <Separator Margin="0,10"/>

                <TextBlock Text="Name: Juan Dela Cruz"
                           FontSize="18"
                           Margin="0,10"/>

                <TextBlock Text="Student ID: 20250001"
                           FontSize="18"
                           Margin="0,5"/>

                <Separator Margin="0,15"/>

                <TextBlock Text="Purchased Items"
                           FontSize="22"
                           FontWeight="Bold"/>

                <DataGrid x:Name="dgReceipt"
                          Height="180"
                          Margin="0,15"
                          AutoGenerateColumns="True"/>

                <TextBlock Text="Remaining Balance"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,20,0,5"/>

                <TextBlock Text="₱375.00"
                           FontSize="30"
                           Foreground="Blue"
                           FontWeight="Bold"/>

                <Button Content="Done"
                        Width="150"
                        Height="45"
                        HorizontalAlignment="Center"
                        Margin="0,25"
                        Click="btnDone_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>