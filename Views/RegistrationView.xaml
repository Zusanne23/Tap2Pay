<Window x:Class="Tap2PaySystem.Views.RegistrationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Registration"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="Gray"
                BorderThickness="1"
                Padding="15">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Full Name"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="txtFullName"
                         Grid.Column="1"
                         Margin="5"/>

                <TextBlock Text="Username"
                           Grid.Row="1"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="txtUsername"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="5"/>

                <TextBlock Text="Password"
                           Grid.Row="2"
                           VerticalAlignment="Center"/>

                <PasswordBox x:Name="txtPassword"
                             Grid.Row="2"
                             Grid.Column="1"
                             Margin="5"/>

                <TextBlock Text="RFID UID"
                             Grid.Row="3"
                             VerticalAlignment="Center"/>     

                <Grid Grid.Row="3"
                              Grid.Column="1">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>

                    <TextBox x:Name="txtRFID"
                           Grid.Row="3"
                           Grid.Column="1"
                           Margin="5"
                           IsReadOnly="True"/>    

                    <Button Grid.Column="1"
                           Margin="5"
                           Content="Scan RFID"
                           Click="btnScanRFID_Click"/> 

                </Grid>

                <TextBox x:Name="txtRFIDScanner"
                           Width="1"
                           Height="1"
                           Opacity="0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           KeyDown="txtRFIDScanner_KeyDown"/>     

                <TextBlock Text="Role"
                           Grid.Column="2"
                           VerticalAlignment="Center"/>

                <ComboBox x:Name="cbRole"
                          Grid.Column="3"
                          Margin="5">

                         <ComboBoxItem Content="User"/>
                          <ComboBoxItem Content="Cashier"/>

                </ComboBox>

                <TextBlock Text="Status"
                           Grid.Row="1"
                           Grid.Column="2"
                           VerticalAlignment="Center"/>

                <ComboBox x:Name="cbStatus"
                          Grid.Row="1"
                          Grid.Column="3"
                          Margin="5">
                    <ComboBoxItem Content="Active"/>
                    <ComboBoxItem Content="Inactive"/>
                </ComboBox>

                <TextBlock Text="Balance"
                           Grid.Row="2"
                           Grid.Column="2"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="txtBalance"
                         Grid.Row="2"
                         Grid.Column="3"
                         Text="0.00"
                         Margin="5"/>

                <Button x:Name="btnSave"
                        Grid.Row="4"
                        Grid.Column="3"
                        Content="SAVE USER"
                        Width="150"
                        Height="35"
                        HorizontalAlignment="Right"
                        Click="btnSave_Click"/>

            </Grid>

        </Border>

        <!-- DataGrid -->
        <DataGrid x:Name="dgUsers"
                  Grid.Row="1"
                  Margin="0,20,0,0"
                  AutoGenerateColumns="True"/>


    </Grid>

</Window>