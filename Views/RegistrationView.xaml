<Window x:Class="Tap2PayAdmin.Views.RegistrationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Registration"
        Height="760"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <DockPanel Margin="0,0,0,20">

            <Button x:Name="btnBack"
                    Width="40"
                    Height="35"
                    Content="←"
                    Click="btnBack_Click"
                    DockPanel.Dock="Left"/>

            <TextBlock Text="User Registration"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="15,0,0,0"
                       VerticalAlignment="Center"/>

        </DockPanel>

        <!-- DASHBOARD -->
        <UniformGrid Grid.Row="1"
                     Columns="3"
                     Margin="0,0,0,20">

            <Border Background="#3498DB"
                    CornerRadius="10"
                    Margin="5">

                <StackPanel Margin="15">
                    <TextBlock Text="Total Users"
                               Foreground="White"/>
                    <TextBlock x:Name="txtTotalUsers"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>

            </Border>

            <Border Background="#2ECC71"
                    CornerRadius="10"
                    Margin="5">

                <StackPanel Margin="15">
                    <TextBlock Text="Active Users"
                               Foreground="White"/>
                    <TextBlock x:Name="txtActiveUsers"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>

            </Border>

            <Border Background="#9B59B6"
                    CornerRadius="10"
                    Margin="5">

                <StackPanel Margin="15">
                    <TextBlock Text="Cashiers"
                               Foreground="White"/>
                    <TextBlock x:Name="txtCashiers"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>

            </Border>

        </UniformGrid>

        <!-- REGISTRATION FORM -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="60"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Full Name"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <TextBox x:Name="txtFullName"
                         Grid.Column="1"
                         Height="35"/>

                <TextBlock Text="Username"
                           Grid.Row="1"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <TextBox x:Name="txtUsername"
                         Grid.Row="1"
                         Grid.Column="1"
                         Height="35"/>

                <TextBlock Text="Password"
                           Grid.Row="2"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <PasswordBox x:Name="txtPassword"
                             Grid.Row="2"
                             Grid.Column="1"
                             Height="35"/>

                <TextBlock Text="RFID UID"
                           Grid.Row="3"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <Grid Grid.Row="3"
                      Grid.Column="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="txtRFID"
                             Height="35"
                             IsReadOnly="True"/>

                    <Button Grid.Column="1"
                            Margin="10,0,0,0"
                            Background="#3498DB"
                            Foreground="White"
                            Content="Scan RFID"
                            Click="btnScanRFID_Click"/>

                </Grid>

                <TextBlock Text="Role"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <ComboBox x:Name="cbRole"
                          Grid.Column="3"
                          Height="35">

                    <ComboBoxItem Content="User"/>
                    <ComboBoxItem Content="Cashier"/>

                </ComboBox>

                <TextBlock Text="Status"
                           Grid.Row="1"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <ComboBox x:Name="cbStatus"
                          Grid.Row="1"
                          Grid.Column="3"
                          Height="35">

                    <ComboBoxItem Content="Active"/>
                    <ComboBoxItem Content="Inactive"/>

                </ComboBox>

                <TextBlock Text="Balance"
                           Grid.Row="2"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <TextBox x:Name="txtBalance"
                         Grid.Row="2"
                         Grid.Column="3"
                         Height="35"
                         Text="0.00"/>

                <Button x:Name="btnSave"
                        Grid.Row="4"
                        Grid.Column="3"
                        Width="180"
                        Height="40"
                        HorizontalAlignment="Right"
                        Background="#2563EB"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        Content="SAVE USER"
                        Click="btnSave_Click"/>

                <!-- Hidden RFID Reader -->
                <TextBox x:Name="txtRFIDScanner"
                         Width="1"
                         Height="1"
                         Opacity="0"
                         Focusable="True"
                         KeyDown="txtRFIDScanner_KeyDown"/>

            </Grid>

        </Border>

        <!-- USERS TABLE -->
        <DataGrid x:Name="dgUsers"
                  Grid.Row="3"
                  AutoGenerateColumns="True"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  RowHeight="35"
                  HeadersVisibility="Column"/>

    </Grid>

</Window>