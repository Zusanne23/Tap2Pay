<Window x:Class="Tap2PayAdmin.Views.TapRFIDView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tap RFID Card"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4F6F9">

    <Grid>

        <Border Width="500"
                Height="350"
                Background="White"
                CornerRadius="15"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="READY FOR PAYMENT"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,20"/>

                <TextBlock Text="Please Tap your RFID Card"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           Margin="0,10"/>

                <TextBlock Text="Waiting for RFID..."
                           FontSize="22"
                           Foreground="Blue"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,40"/>

                <Button Content="Simulate RFID"
                        Width="180"
                        Height="45"
                        HorizontalAlignment="Center"
                        Margin="0,30"
                        Click="btnRFID_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>