<Window x:Class="Tap2PayAdmin.Views.ManagerDashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tap2Pay - Manager Dashboard"
        Height="730"
        Width="1300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4F6F9">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1F2937">

            <StackPanel>

                <TextBlock Text="Tap2Pay"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,25,0,5"/>

                <TextBlock Text="Manager Panel"
                           Foreground="White"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <Button Content="🏠 Dashboard"
                        Height="30"
                        Margin="10"/>

                <Button Content="🛒 POS"
                        Height="30"
                        Margin="10"
                        Click="btnPOS_Click"/>

                <Button Content="👤 Registration"
                        Height="30"
                        Margin="10"
                        Click="btnRegistration_Click"/>

                <Button Content="👥 User Management"
                        Height="30"
                        Margin="10"
                        Click="btnUsers_Click"/>

                <Button Content="📦 Inventory"
                        Height="30"
                        Margin="10"
                        Click="btnInventory_Click"/>

                <Button Content="🍔 Products"
                        Height="30"
                        Margin="10"
                        Click="btnProducts_Click"/>

                <Button Content="💳 Top Up"
                        Height="30"
                        Margin="10"
                        Click="btnTopUp_Click"/>

                <Button x:Name="btnTopUpHistory"
                        Content="🧾 Top Up History"
                        Height="30"
                        Margin="10"
                        Click="btnTopUpHistory_Click"/>

                <Button Content="📄 Transaction History"
                        Height="30"
                        Margin="10"
                        Click="btnTransactionHistory_Click"/>

                <Button Content="📊 Reports"
                        Height="30"
                        Margin="10"
                        Click="btnReports_Click"/>

                <Button x:Name="btnActivityLogs"
                        Content="📋 Activity Logs"
                        Height="30"
                        Margin="10"
                        Click="btnActivityLogs_Click"/>

                <Button Content="🚪 Logout"
                        Height="30"
                        Click="btnLogout_Click" Width="200"/>

            </StackPanel>

        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="120"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="White"
            CornerRadius="10"
            Padding="20">

                <DockPanel>

                    <StackPanel>

                        <TextBlock Text="DASHBOARD"
                           FontSize="28"
                           FontWeight="Bold"/>

                        <TextBlock x:Name="txtDate"
                           Foreground="Gray"
                           FontSize="14"/>

                    </StackPanel>

                </DockPanel>

            </Border>

            <!-- Summary Cards -->
            <UniformGrid Grid.Row="1"
                 Columns="4"
                 Margin="0,20,0,20">

                <Border Background="#3498DB" CornerRadius="10" Margin="5">
                    <StackPanel Margin="15">
                        <TextBlock Text="Total Sales" Foreground="White"/>
                        <TextBlock x:Name="txtSales"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Background="#27AE60" CornerRadius="10" Margin="5">
                    <StackPanel Margin="15">
                        <TextBlock Text="Transactions" Foreground="White"/>
                        <TextBlock x:Name="txtTransactions"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Background="#F39C12" CornerRadius="10" Margin="5">
                    <StackPanel Margin="15">
                        <TextBlock Text="Registered Users" Foreground="White"/>
                        <TextBlock x:Name="txtUsers"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Background="#8E44AD" CornerRadius="10" Margin="5">
                    <StackPanel Margin="15">
                        <TextBlock Text="Total Top Up" Foreground="White"/>
                        <TextBlock x:Name="txtTopUp"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Bottom -->
            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <GroupBox Header="Recent Transactions"
                  Margin="0,0,10,0">

                    <DataGrid x:Name="dgRecentTransactions"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"/>

                </GroupBox>

                <GroupBox Grid.Column="1"
                  Header="Recent Activities">

                    <ListBox x:Name="lstActivity"/>

                </GroupBox>

            </Grid>

        </Grid>
    </Grid>

</Window>